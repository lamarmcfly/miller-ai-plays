# Azure AD App Registration (for Microsoft Graph API)
# Create at: portal.azure.com → Azure Active Directory → App registrations
# Required permissions: Sites.ReadWrite.All, Files.ReadWrite.All
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# SharePoint site info (populated after running setup:sharepoint)
SP_SITE_HOSTNAME=yourtenant.sharepoint.com
SP_SITE_PATH=/sites/MillerAIPlays
